# ============================================================
# TIMEFLOW — Environment Variables Reference
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=8000
NODE_ENV=production          # development | production

# ── Database ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=timeflow
DB_PASSWORD=your_db_password
DB_NAME=timesheet_db

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Wrike Integration ───────────────────────────────────────
WRIKE_API_KEY=your_wrike_api_key
WRIKE_API_BASE_URL=https://www.wrike.com/api/v4
WRIKE_FOLDER_ID=your_wrike_folder_id
WRIKE_WEBHOOK_SECRET=any_random_secret   # validates incoming webhook calls

# ── URLs ────────────────────────────────────────────────────
APP_URL=https://your-api-domain.com      # used in webhook registration URLs
FRONTEND_URL=https://your-app-domain.com # used for CORS allow-origin

# ── Payroll Defaults ────────────────────────────────────────
DEFAULT_HOURLY_RATE=500     # fallback hourly rate when not set on employee
CURRENCY=PHP                # default display currency (PHP | USD | BDT)

# ── Company Identity (shown in payslip PDFs) ────────────────
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Full company address here
COMPANY_WEBSITE=yourcompany.com

# ── Payor Details (BIR bank file fields) ────────────────────
PAYOR_NAME=Your Company Legal Name
PAYOR_TIN=000-000-000-000
PAYOR_ADDRESS=Company address for BIR filings
PAYOR_ZIP_CODE=0000

# ── Bank Transfer File ──────────────────────────────────────
BANK_SOURCE_ACCOUNT=       # source account number for XCS/DFT transfer files

# ── Scheduling ──────────────────────────────────────────────
CRON_SCHEDULE=0 9 * * 1    # cron expression (default: Monday 9 AM)
TIMEZONE=Asia/Manila        # timezone for cron jobs
APPROVAL_REMINDER_DAYS=3   # days before sending approval reminders

# ── Redis Cache (optional) ──────────────────────────────────
# Leave blank / commented out to run without caching.
# REDIS_URL=redis://localhost:6379
