# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=timesheet_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Wrike API Configuration
WRIKE_API_KEY=your_wrike_api_key
WRIKE_API_BASE_URL=https://www.wrike.com/api/v4
WRIKE_FOLDER_ID=your_folder_id_for_approval_tasks
WRIKE_WEBHOOK_SECRET=your_webhook_secret

# Google Drive Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

# Application Configuration
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Cron Schedule (default: every Monday at 9 AM)
CRON_SCHEDULE=0 9 * * 1

# Rate Configuration
DEFAULT_HOURLY_RATE=500
CURRENCY=BDT
